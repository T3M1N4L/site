---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, height=device-height, initial-scale=1.0, user-scalable=no, maximum-scale=1.0, minimal-ui"
    />
    <title>&nbsp;</title>
    <link
      rel="icon"
      type="image/x-icon"
      href="https://soggy.cat/static/other/shared/svgs/blank.svg"
    />

    <meta itemprop="name" content="404" />
    <meta itemprop="description" content="this page doesn't even exist man!! scram" />

    <style>
      body {
        margin: 0;
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background-color: #fff;
        cursor: none;
        overflow: hidden;
      }

      .player {
        width: auto;
        height: 30%;
        display: block;
      }

      audio {
        display: none;
      }

      .waiting {
        position: fixed;
        display: none;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        width: 100%;
        height: 100vh;
        background-color: black;
        color: white;
        opacity: 0.5;
        z-index: 2000;
        cursor: pointer;
        font-family: "Segoe UI", "Open Sans", "Helvetica Neue", sans-serif;
      }

      .atext {
        color: #d7d7d7;
        font-size: 12.5px;
        user-select: none;
        z-index: 2500;
      }

      .amini {
        color: rgb(133 133 133 / 50%);
        font-size: 10.5px;
        font-style: normal;
        text-decoration: dotted;
        user-select: none;
        position: absolute;
        bottom: 15px;
        z-index: 2500;
      }

      .dilemma {
        position: fixed;
        max-width: 60%;
        height: auto;
        max-height: 90%;
        object-fit: contain;
        z-index: 3000;
        display: none;
      }

      .bgtext {
        position: fixed;
        color: rgb(133 133 133 / 5%);
        font-family: "Franklin Gothic Medium", "Arial Narrow", Arial, sans-serif;
        font-size: calc(250px + (100vw - 1000px) * 0.1);
        transform: skewX(-15deg);
        z-index: -999;
        user-select: none;
      }

      .subtitles {
        position: fixed;
        text-align: center;
        bottom: 10px;
        left: 0;
        width: 100%;
        font-size: 1rem;
        color: black;
        pointer-events: none;
        z-index: 1000;
        padding: 10px;
        letter-spacing: -0.5px;
        font-family: Arial, sans-serif;
        font-style: italic;
        font-stretch: condensed;
      }

      @keyframes swirl {
        0% {
          transform: rotate(-540deg) scale(0);
          opacity: 0;
        }

        100% {
          transform: rotate(0) scale(1);
          opacity: 1;
        }
      }

      @keyframes fadeout {
        0% {
          opacity: 1;
        }

        100% {
          opacity: 0;
        }
      }

      @keyframes shake {
        0% {
          transform: translate(0);
        }

        20% {
          transform: translate(-1px, 1px);
        }

        40% {
          transform: translate(-1px, -1px);
        }

        60% {
          transform: translate(1px, 1px);
        }

        80% {
          transform: translate(1px, -1px);
        }

        100% {
          transform: translate(0);
        }
      }

      .red {
        color: rgb(255 0 0);
      }

      .bred {
        color: rgb(245 77 77);
      }

      .shake {
        display: inline-block;
        animation: shake 0.2s linear infinite both;
        position: relative;
      }

      html > div[style] {
        display: none !important;
      }
    </style>
  </head>
  <body>
    <div class="waiting">
      <img
        class="paw"
        width="50"
        draggable="false"
        src="https://soggy.cat/static/ssoggycat/team/images/paw.png"
        alt=""
      />
      <a class="atext">autoplay fallback: click to play</a>

      <a class="amini">huh? why is this needed?</a>
      <audio class="audio2">
        <source src="/wukko/audio/fanfare.mp3" type="audio/mpeg" />
      </audio>
    </div>

    <img
      class="dilemma"
      draggable="false"
      src="https://soggy.cat/static/ssoggycat/main/images/autoplay.webp"
      alt=""
    />

    <a class="bgtext">404</a>

    <img class="player" alt="" draggable="false" />
    <div class="subtitles"></div>

    <audio
      class="audio"
      autoplay
      loop
      preload="auto"
      src="/wukko/audio/fromthestart.mp3"
    ></audio>

    <script type="module" is:inline>
      import { BlobReader, BlobWriter, ZipReader } from "https://cdn.jsdelivr.net/npm/@zip.js/zip.js@2.7.57/+esm";

      document.addEventListener("DOMContentLoaded", () => {
        const fps = 10;
        const totalFrames = 1633;
        const player = document.querySelector(".player");
        const audio = document.querySelector(".audio");
        const waiting = document.querySelector(".waiting");
        const waitingText = document.querySelector(".atext");
        const subtitles = document.querySelector(".subtitles");
        const dilemma = document.querySelector(".dilemma");
        const audio2 = document.querySelector(".audio2");
        let currentFrame = 1;
        let requestedFrame = 1;
        let cues = [];
        const frameEntries = [];
        const frameUrls = new Map();
        const framePromises = new Map();
        let zipReady = false;

        const loadFramesZip = async () => {
          waitingText.textContent = "loading zipped frames...";
          const response = await fetch("/wukko/frames.zip");
          const blob = await response.blob();
          const zipReader = new ZipReader(new BlobReader(blob));
          const entries = await zipReader.getEntries();

          frameEntries.push(
            ...entries
              .filter((entry) => entry.filename.endsWith(".webp"))
              .sort((left, right) => left.filename.localeCompare(right.filename)),
          );

          zipReady = frameEntries.length === totalFrames;
          waitingText.textContent = "autoplay fallback: click to play";
        };

        const getFrameUrl = async (frameNumber) => {
          if (frameUrls.has(frameNumber)) {
            return frameUrls.get(frameNumber);
          }

          if (framePromises.has(frameNumber)) {
            return framePromises.get(frameNumber);
          }

          const entry = frameEntries[frameNumber - 1];
          if (!entry) {
            return null;
          }

          const promise = entry
            .getData(new BlobWriter("image/webp"))
            .then((blob) => {
              const url = URL.createObjectURL(blob);
              frameUrls.set(frameNumber, url);
              framePromises.delete(frameNumber);
              return url;
            })
            .catch((error) => {
              framePromises.delete(frameNumber);
              throw error;
            });

          framePromises.set(frameNumber, promise);
          return promise;
        };

        const preloadFrame = (frameNumber) => {
          if (!zipReady || frameNumber > totalFrames) {
            return;
          }

          void getFrameUrl(frameNumber);
        };

        const renderFrame = async (time) => {
          if (!zipReady) {
            return;
          }

          const frameNumber = Math.min(totalFrames, Math.max(1, Math.floor(time * fps) + 1));
          if (frameNumber === currentFrame || frameNumber === requestedFrame) {
            return;
          }

          requestedFrame = frameNumber;
          const url = await getFrameUrl(frameNumber);
          if (!url || requestedFrame !== frameNumber) {
            return;
          }

          currentFrame = frameNumber;
          player.src = url;

          for (let nextFrame = frameNumber + 1; nextFrame <= frameNumber + 4; nextFrame += 1) {
            preloadFrame(nextFrame);
          }
        };

        const parseTimestamp = (value) => {
          const [hours, minutes, seconds] = value.split(":");
          return Number(hours) * 3600 + Number(minutes) * 60 + Number(seconds);
        };

        const parseVtt = (vtt) =>
          vtt
            .replace(/\r/g, "")
            .split(/\n\n+/)
            .flatMap((block) => {
              const lines = block.split("\n").filter(Boolean);
              if (!lines.length || lines[0] === "WEBVTT" || lines[0].startsWith("NOTE")) {
                return [];
              }

              const timelineIndex = lines.findIndex((line) => line.includes("-->"));
              if (timelineIndex === -1) {
                return [];
              }

              const [start, end] = lines[timelineIndex]
                .split("-->")
                .map((part) => part.trim().split(" ")[0]);
              const html = lines.slice(timelineIndex + 1).join("<br>");

              if (!html) {
                return [];
              }

              return [{ start: parseTimestamp(start), end: parseTimestamp(end), html }];
            });

        const updateSubtitles = (time) => {
          const cue = cues.find((item) => time >= item.start && time < item.end);
          subtitles.innerHTML = cue ? cue.html : "";
        };

        const tick = () => {
          void renderFrame(audio.currentTime);
          updateSubtitles(audio.currentTime);
          requestAnimationFrame(tick);
        };

        const showFallback = () => {
          waiting.style.display = "flex";
        };

        const hideFallback = () => {
          waiting.style.display = "none";
        };

        const attemptAutoplay = async () => {
          try {
            hideFallback();
            await audio.play();
          } catch {
            showFallback();
          }
        };

        waiting.addEventListener("click", async (event) => {
          if (!event.target.classList.contains("amini")) {
            hideFallback();
            await attemptAutoplay();
            if (document.documentElement.requestFullscreen) {
              document.documentElement.requestFullscreen().catch(() => {});
            }
          }
        });

        document.querySelector(".amini").addEventListener("click", (event) => {
          event.stopPropagation();
          audio2.play().catch(() => {});
          dilemma.style.display = "block";
          dilemma.style.animation = "swirl 9s linear both";
          waiting.style.pointerEvents = "none";

          setTimeout(() => {
            dilemma.style.animation = "fadeout 1s linear both";
            setTimeout(() => {
              dilemma.style.display = "none";
              waiting.style.pointerEvents = "auto";
            }, 1000);
          }, 9500);
        });

        setInterval(() => {
          document.title = Array.from(
            { length: Math.floor(Math.random() * 10) + 1 },
            () => String.fromCodePoint(Math.floor(Math.random() * (0x2fff - 0x20)) + 0x20),
          ).join("");
        }, 100);

        Promise.all([
          fetch("/wukko/404.vtt")
            .then((response) => response.text())
            .then((text) => {
              cues = parseVtt(text);
            })
            .catch(() => {
              cues = [];
            }),
          loadFramesZip(),
        ]).then(async () => {
          player.src = (await getFrameUrl(1)) ?? "";

          for (let frameNumber = 1; frameNumber <= 5; frameNumber += 1) {
            preloadFrame(frameNumber);
          }

          tick();
          attemptAutoplay();
        });
      });
    </script>
  </body>
</html>
