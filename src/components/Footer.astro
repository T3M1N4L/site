---
import gitInfo from '../generated/git.json' assert { type: 'json' };
const currentYear = new Date().getFullYear();
const nextYear = currentYear + 1;
---

<footer class="site-footer" data-ascii-footer>
  <div class="footer-mural" aria-hidden="true">
    <pre class="ascii-layer ascii-base" data-ascii-base data-pretext-ascii data-pretext-sample="MMMMMMMMMM"></pre>
    <pre class="ascii-layer ascii-glow" data-ascii-glow></pre>
    <div class="ascii-hover-glow"></div>
  </div>

  <div class="inner footer-content">
    <div class="footer-copy">
      <h4 style="margin: 0;">&copy; {currentYear}-{nextYear} t3rm1n4l</h4>
      <p style="margin: 0;">made with bun and astro | this is a <strong><blink>&lt;/blink&gt;</blink> free zone</strong></p>
      <p style="margin: 0;">last commit hash: <code style="user-select: all;">{gitInfo.commitHash}</code></p>
    </div>

    <div id="konami">
      <kbd id="k0">&#8593;</kbd>
      <kbd id="k1">&#8593;</kbd>
      <kbd id="k2">&#8595;</kbd>
      <kbd id="k3">&#8595;</kbd>
      <kbd id="k4">&#8592;</kbd>
      <kbd id="k5">&#8594;</kbd>
      <kbd id="k6">&#8592;</kbd>
      <kbd id="k7">&#8594;</kbd>
      <kbd id="k8">b</kbd>
      <kbd id="k9">a</kbd>
      <a id="lazy" class="no-style socials" data-haptic="buzz" data-pretext-fit>too lazy?</a>
    </div>
  </div>
</footer>

<script is:inline>
  (() => {
    const chars = " .'`^\",:;Il!i><~+_-?][}{1)(|\\\\/tfjrxnuvczXYUJCLQ0OZmwqpdbkhao*#MW&8%B@$";
    const hoverWord = "t3rm1n4l";
    const setups = new WeakMap();

    const getTargetChar = (row, col) => {
      return hoverWord[(row + col) % hoverWord.length];
    };

    function setupFooter(footer) {
      if (!footer || setups.has(footer)) {
        return;
      }

      const baseEl = footer.querySelector("[data-ascii-base]");
      const glowEl = footer.querySelector("[data-ascii-glow]");
      const muralEl = footer.querySelector(".footer-mural");
      if (!baseEl || !glowEl) {
        return;
      }

      const state = {
        grid: [],
        rows: 0,
        cols: 0,
        interval: null,
        hoverRow: null,
        hoverCol: null,
      };

      const buildGrid = () => {
        const style = getComputedStyle(baseEl);
        const charWidthFromPretext = Number.parseFloat(style.getPropertyValue("--ascii-char-width"));
        const lineHeightFromPretext = Number.parseFloat(style.getPropertyValue("--ascii-line-height"));
        const fallbackCharWidth = parseFloat(style.fontSize) * 0.62 || 7;
        const fallbackLineHeight = parseFloat(style.lineHeight) || 12;
        const charWidth = Math.max(
          4,
          (Number.isFinite(charWidthFromPretext) ? charWidthFromPretext : fallbackCharWidth) * 0.92
        );
        const lineHeight = Math.max(
          10,
          Number.isFinite(lineHeightFromPretext) ? lineHeightFromPretext : fallbackLineHeight
        );
        const muralWidth = Math.max(0, muralEl?.clientWidth || footer.clientWidth || 0);
        const effectiveCharWidth = Math.max(1, charWidth * 0.9);
        state.cols = Math.max(40, Math.ceil((muralWidth + 640) / effectiveCharWidth));
        const muralHeight = Math.max(0, muralEl?.clientHeight || footer.clientHeight || 0);
        state.rows = Math.max(14, Math.ceil((muralHeight / lineHeight) + 6));
        state.grid = Array.from({ length: state.rows }, () =>
          Array.from({ length: state.cols }, () => chars[Math.floor(Math.random() * chars.length)])
        );
      };

      const render = () => {
        const text = state.grid.map((row) => row.join("")).join("\n");
        baseEl.textContent = text;
        glowEl.textContent = text;
      };

      const tick = () => {
        const updates = Math.max(60, Math.floor(state.rows * state.cols * 0.018));
        for (let i = 0; i < updates; i++) {
          const row = Math.floor(Math.random() * state.rows);
          const col = Math.floor(Math.random() * state.cols);
          state.grid[row][col] = chars[Math.floor(Math.random() * chars.length)];
        }

        if (typeof state.hoverRow === "number" && typeof state.hoverCol === "number") {
          for (let rowOffset = -1; rowOffset <= 1; rowOffset++) {
            const row = state.hoverRow + rowOffset;
            if (row < 0 || row >= state.rows) {
              continue;
            }

            const strength = rowOffset === 0 ? 0.92 : 0.5;
            const spread = Math.max(4, Math.floor(hoverWord.length * 0.75));
            const start = Math.max(0, state.hoverCol - spread);
            const end = Math.min(state.cols - 1, state.hoverCol + spread);

            for (let col = start; col <= end; col++) {
              if (Math.random() < strength) {
                state.grid[row][col] = getTargetChar(row, col);
              }
            }
          }
        }

        render();
      };

      const updateHover = (event) => {
        const rect = (muralEl || footer).getBoundingClientRect();
        const x = Math.max(0, Math.min(event.clientX - rect.left, rect.width));
        const y = Math.max(0, Math.min(event.clientY - rect.top, rect.height));
        footer.style.setProperty("--ascii-hover-x", `${x}px`);
        footer.style.setProperty("--ascii-hover-y", `${y}px`);

        const col = Math.floor((x / Math.max(rect.width, 1)) * state.cols);
        const row = Math.floor((y / Math.max(rect.height, 1)) * state.rows);
        state.hoverCol = Math.max(0, Math.min(state.cols - 1, col));
        state.hoverRow = Math.max(0, Math.min(state.rows - 1, row));

        footer.classList.add("ascii-hovering");
      };

      const handleLeave = () => {
        state.hoverRow = null;
        state.hoverCol = null;
        footer.classList.remove("ascii-hovering");
      };

      const rebuild = () => {
        buildGrid();
        render();
      };

      rebuild();
      state.interval = window.setInterval(tick, 90);

      footer.addEventListener("pointermove", updateHover);
      footer.addEventListener("pointerleave", handleLeave);
      window.addEventListener("resize", rebuild, { passive: true });

      setups.set(footer, {
        teardown() {
          if (state.interval) {
            clearInterval(state.interval);
          }
          footer.removeEventListener("pointermove", updateHover);
          footer.removeEventListener("pointerleave", handleLeave);
          window.removeEventListener("resize", rebuild);
        }
      });
    }

    function initAsciiFooter() {
      document.querySelectorAll("[data-ascii-footer]").forEach((footer) => {
        setupFooter(footer);
      });
    }

    document.addEventListener("astro:before-swap", () => {
      document.querySelectorAll("[data-ascii-footer]").forEach((footer) => {
        const setup = setups.get(footer);
        setup?.teardown();
        setups.delete(footer);
      });
    });

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initAsciiFooter, { once: true });
    } else {
      initAsciiFooter();
    }

    document.addEventListener("astro:page-load", initAsciiFooter);
  })();
</script>

<style>
  .site-footer {
    position: relative;
    --ascii-hover-x: 50%;
    --ascii-hover-y: 50%;
    --ascii-bleed: clamp(28px, 7vw, 56px);
    --ascii-lift: clamp(8px, 1.8vw, 14px);
    overflow: hidden;
    background: oklch(var(--base));
  }

  .site-footer::before {
    display: none;
  }

  .site-footer::after {
    content: "";
    position: absolute;
    background: linear-gradient(
      90deg,
      oklch(var(--color) / 0) 25%,
      oklch(var(--color) / 1) 50%,
      oklch(var(--color) / 0) 75%
    );
    width: 100%;
    height: 1px;
    top: 0;
    opacity: 0.5;
    z-index: 2;
    pointer-events: none;
  }

  .footer-mural {
    position: absolute;
    top: calc(-1 * var(--ascii-lift));
    left: 50%;
    width: 100vw;
    transform: translateX(-50%);
    right: auto;
    bottom: 0;
    overflow: hidden;
    pointer-events: none;
    user-select: none;
    mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      rgb(0 0 0 / 0.03) 3%,
      rgb(0 0 0 / 0.1) 7%,
      rgb(0 0 0 / 0.22) 12%,
      rgb(0 0 0 / 0.4) 17%,
      rgb(0 0 0 / 0.62) 22%,
      rgb(0 0 0 / 0.82) 26%,
      black 29%,
      black 100%
    );
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      rgb(0 0 0 / 0.03) 3%,
      rgb(0 0 0 / 0.1) 7%,
      rgb(0 0 0 / 0.22) 12%,
      rgb(0 0 0 / 0.4) 17%,
      rgb(0 0 0 / 0.62) 22%,
      rgb(0 0 0 / 0.82) 26%,
      black 29%,
      black 100%
    );
    z-index: 0;
  }

  .footer-mural::after {
    display: none;
  }

  .ascii-layer {
    position: absolute;
    inset-block: 0;
    left: -48px;
    right: -48px;
    margin: 0;
    padding: 0;
    overflow: hidden;
    white-space: pre;
    font-family: var(--monospace);
    font-size: 12px;
    line-height: 12px;
    letter-spacing: 0;
  }

  .ascii-base {
    color: oklch(var(--overlay1) / 0.075);
  }

  .ascii-glow {
    color: oklch(var(--color) / 0.045);
    text-shadow:
      0 0 0.2rem oklch(var(--color) / 0.04),
      0 0 0.45rem oklch(var(--color) / 0.02);
    opacity: 0;
    transition: opacity 180ms ease;
    mask-image: radial-gradient(
      160px 72px at var(--ascii-hover-x) var(--ascii-hover-y),
      black 0%,
      rgb(0 0 0 / 0.6) 24%,
      transparent 76%
    );
  }

  .ascii-hovering .ascii-glow {
    opacity: 0.7;
  }

  .ascii-hover-glow {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 180ms ease;
    background:
      radial-gradient(
        180px 84px at var(--ascii-hover-x) var(--ascii-hover-y),
        oklch(var(--color) / 0.02) 0%,
        oklch(var(--color) / 0.01) 28%,
        transparent 72%
      );
    mix-blend-mode: screen;
  }

  .ascii-hovering .ascii-hover-glow {
    opacity: 0.45;
  }

  .footer-content {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.25rem;
  }

  .footer-copy {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    max-width: 36rem;
  }

  @media (max-width: 700px) {
    .site-footer {
      --ascii-bleed: clamp(40px, 12vw, 76px);
    }

    .footer-content {
      align-items: flex-start;
    }

    .ascii-layer {
      font-size: 10px;
      line-height: 10px;
    }
  }
</style>
