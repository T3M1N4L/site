<script is:inline>
    const THEME_CLASSES = ['UwU', 'monospace'];

    function updateThemeClass() {
    const theme = window.localStorage.getItem("theme") || '';
        const retroEnabled = window.localStorage.getItem("retro") === "true";

            document.body.classList.remove(...THEME_CLASSES);
            document.body.classList.remove('retro');

            if (theme) {
                document.body.classList.add(theme);
            }

            if (retroEnabled) {
                document.body.classList.add('retro');
            }
  }

  function toggleUwU() {
      window.localStorage.setItem("theme", 'UwU');
      updateThemeClass();
  }

  function toggleMonospace() {
      window.localStorage.setItem("theme", 'monospace');
      updateThemeClass();
  }

  function toggleNormal() {
      window.localStorage.setItem("theme", '');
      updateThemeClass();
  }

    updateThemeClass();
    document.addEventListener("DOMContentLoaded", updateThemeClass);
    document.addEventListener("astro:page-load", updateThemeClass);
</script>
